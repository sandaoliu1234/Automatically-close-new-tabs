{
    "manifest_version": 3,
    "name": "Auto Close New Tab",
    "version": "1.0",
    "description": "Automatically close new tab pages when mouse leaves and close excess new tabs",
    "permissions": [
        "tabs",
        "scripting",
        "storage"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "popup.html"
    },
    "icons": {
        "16": "icon.png",
        "48": "icon.png",
        "128": "icon.png"
    }
}